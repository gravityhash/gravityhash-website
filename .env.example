# Where contact-form messages are delivered
CONTACT_TO=hello@gravityhash.com

# SMTP credentials — required to actually send mail.
# Without these, the server logs submissions and returns success (useful for local dev).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@gravityhash.com
SMTP_PASS=changeme
SMTP_FROM=GravityHash Website <postmaster@gravityhash.com>

# Server
PORT=3000
