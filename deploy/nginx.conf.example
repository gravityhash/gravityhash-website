# Drop into /etc/nginx/sites-available/gravityhash.com and symlink to sites-enabled.
# Then run: certbot --nginx -d gravityhash.com -d www.gravityhash.com
# This file is just a starter — adjust paths and hostnames to your VPS.

server {
    listen 80;
    listen [::]:80;
    server_name gravityhash.com www.gravityhash.com;

    # Redirect all plain-HTTP to HTTPS.
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name gravityhash.com www.gravityhash.com;

    # Managed by certbot once you run it.
    # ssl_certificate     /etc/letsencrypt/live/gravityhash.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/gravityhash.com/privkey.pem;

    # Reasonable defaults
    add_header X-Frame-Options       "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff"   always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    client_max_body_size 1m;
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
